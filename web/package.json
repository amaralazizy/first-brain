    "boneyard-js": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
