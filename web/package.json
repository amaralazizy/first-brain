    "db:studio": "drizzle-kit studio --config=../packages/db/drizzle.config.ts",
    "seed": "tsx --tsconfig tsconfig.json scripts/seed.ts"
  },
  "dependencies": {
    "@first-brain/config": "workspace:*",
